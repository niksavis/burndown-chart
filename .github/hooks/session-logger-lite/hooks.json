{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "python .github/hooks/scripts/session_logger.py session_start",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python .github/hooks/scripts/session_logger.py session_end",
        "timeout": 10
      }
    ]
  }
}
