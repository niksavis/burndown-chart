{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "python .github/hooks/scripts/governance_audit.py session_start",
        "timeout": 10
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "python .github/hooks/scripts/governance_audit.py user_prompt_submit",
        "timeout": 15
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python .github/hooks/scripts/governance_audit.py session_end",
        "timeout": 10
      }
    ]
  }
}
