#!/usr/bin/env sh
# burndown-chart pre-commit hook
# Generated by install_hooks.py - do not edit manually; re-run the script instead.
#
# Runs: lint + static analysis for staged Python changes.
# To bypass in an emergency only: git commit --no-verify

# Run beads tracking hook if bd is installed.
if command -v bd >/dev/null 2>&1; then
    export BD_GIT_HOOK=1
    bd hooks run pre-commit "$@"
    _bd_exit=$?
    if [ "$_bd_exit" -eq 3 ]; then _bd_exit=0; fi
    if [ "$_bd_exit" -ne 0 ]; then exit "$_bd_exit"; fi
fi

# Locate the venv Python interpreter (cross-platform).
if [ -f ".venv/Scripts/python.exe" ]; then
    PYTHON=".venv/Scripts/python.exe"   # Windows (Git for Windows sh)
elif [ -f ".venv/bin/python" ]; then
    PYTHON=".venv/bin/python"           # macOS / Linux
elif command -v python3 >/dev/null 2>&1; then
    PYTHON="python3"                    # system fallback
elif command -v python >/dev/null 2>&1; then
    PYTHON="python"                     # system fallback (older installs)
else
    echo "[git-hook] WARNING: Python not found; skipping quality checks." >&2
    exit 0
fi

if [ ! -f "validate.py" ] || [ ! -d ".venv" ]; then
    exit 0  # Not a dev worktree (e.g. bd backup); skip.
fi

# Skip codebase quality checks for beads-backup branch
# (task tracking exchange, not codebase).
_current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
case "$_current_branch" in beads-backup) exit 0 ;; esac

# Prevent overlapping quality runs from multiple terminals/agents.
_lock_dir=".git/.quality-gate.lock"
if ! mkdir "$_lock_dir" 2>/dev/null; then
    echo "[git-hook] pre-commit: quality gate already running in another session." >&2
    echo "[git-hook] pre-commit: wait for completion before committing again." >&2
    exit 1
fi
_cleanup_lock() { rmdir "$_lock_dir" >/dev/null 2>&1 || true; }
trap _cleanup_lock EXIT INT TERM

echo "[git-hook] pre-commit: running lint + static checks..."
"$PYTHON" validate.py --commit
exit $?
