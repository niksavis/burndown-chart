#!/usr/bin/env sh
# burndown-chart pre-push hook
# Generated by install_hooks.py - do not edit manually; re-run the script instead.
#
# Runs: tests-focused gate (pytest coverage).
# This protects the remote branch and other developers from broken code.
# To bypass in an emergency only: git push --no-verify

# Run beads tracking hook if bd is installed.
if command -v bd >/dev/null 2>&1; then
    export BD_GIT_HOOK=1
    bd hooks run pre-push "$@"
    _bd_exit=$?
    if [ "$_bd_exit" -eq 3 ]; then _bd_exit=0; fi
    if [ "$_bd_exit" -ne 0 ]; then exit "$_bd_exit"; fi
fi

# Locate the venv Python interpreter (cross-platform).
if [ -f ".venv/Scripts/python.exe" ]; then
    PYTHON=".venv/Scripts/python.exe"   # Windows (Git for Windows sh)
elif [ -f ".venv/bin/python" ]; then
    PYTHON=".venv/bin/python"           # macOS / Linux
elif command -v python3 >/dev/null 2>&1; then
    PYTHON="python3"                    # system fallback
elif command -v python >/dev/null 2>&1; then
    PYTHON="python"                     # system fallback (older installs)
else
    echo "[git-hook] WARNING: Python not found; skipping quality checks." >&2
    exit 0
fi

if [ ! -f "validate.py" ] || [ ! -d ".venv" ]; then
    exit 0  # Not a dev worktree (e.g. bd backup); skip.
fi

# Read what is being pushed from stdin (format: <local ref> <local sha> ...).
# Skip the quality gate for deletions, tag-only pushes, and beads-backup pushes.
_has_code_push=0
while IFS=' ' read -r local_ref local_sha _remote_ref _remote_sha; do
    # Deletions: local sha is all zeros.
    case "$local_sha" in 0000000000000000000000000000000000000000) continue ;; esac
    # Tag pushes: local ref starts with refs/tags/.
    case "$local_ref" in refs/tags/*) continue ;; esac
    # Beads backup: remote ref is refs/heads/beads-backup
    # (task tracking exchange, not codebase -- skip quality gate).
    case "$_remote_ref" in refs/heads/beads-backup) continue ;; esac
    _has_code_push=1
    break
done
if [ "$_has_code_push" -eq 0 ]; then
    exit 0  # Nothing to validate (delete, tag, or beads-backup push).
fi

# Prevent overlapping quality runs from multiple terminals/agents.
_lock_dir=".git/.quality-gate.lock"
if ! mkdir "$_lock_dir" 2>/dev/null; then
    echo "[git-hook] pre-push: quality gate already running in another session." >&2
    echo "[git-hook] pre-push: wait for completion before pushing again." >&2
    exit 1
fi
_cleanup_lock() { rmdir "$_lock_dir" >/dev/null 2>&1 || true; }
trap _cleanup_lock EXIT INT TERM

# Auto-export beads issue snapshot before pushing code so teammates see it.
if command -v bd >/dev/null 2>&1; then
    bd backup export-git || true
fi

echo "[git-hook] pre-push: running tests-focused quality gate..."
"$PYTHON" validate.py
exit $?
